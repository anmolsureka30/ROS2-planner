<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ackermann_vehicle">

  <!-- Configurable vehicle parameters -->
  <xacro:arg name="wheelbase" default="0.18"/>
  <xacro:arg name="vehicle_length" default="0.30"/>
  <xacro:arg name="vehicle_width" default="0.20"/>
  <xacro:arg name="vehicle_height" default="0.08"/>
  <xacro:arg name="rear_axle_to_back" default="0.06"/>
  <xacro:arg name="wheel_radius" default="0.033"/>
  <xacro:arg name="wheel_width" default="0.025"/>

  <xacro:property name="wheelbase" value="$(arg wheelbase)"/>
  <xacro:property name="vehicle_length" value="$(arg vehicle_length)"/>
  <xacro:property name="vehicle_width" value="$(arg vehicle_width)"/>
  <xacro:property name="vehicle_height" value="$(arg vehicle_height)"/>
  <xacro:property name="rear_axle_to_back" value="$(arg rear_axle_to_back)"/>
  <xacro:property name="wheel_radius" value="$(arg wheel_radius)"/>
  <xacro:property name="wheel_width" value="$(arg wheel_width)"/>

  <xacro:property name="track_width" value="${vehicle_width - wheel_width}"/>
  <xacro:property name="body_z_offset" value="${wheel_radius + 0.01}"/>

  <!-- Colors -->
  <material name="blue"><color rgba="0.2 0.2 0.8 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- Steered wheel macro (for front wheels) -->
  <xacro:macro name="steered_wheel" params="name x y">
    <link name="${name}_steering_link">
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
      </inertial>
    </link>
    <joint name="${name}_steering_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${name}_steering_link"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.6" upper="0.6" effort="10" velocity="5"/>
    </joint>
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="${name}_steering_link"/>
      <child link="${name}_link"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- Base link (at rear axle center) -->
  <link name="base_link">
    <visual>
      <origin xyz="${vehicle_length/2 - rear_axle_to_back} 0 ${body_z_offset}"
              rpy="0 0 0"/>
      <geometry>
        <box size="${vehicle_length} ${vehicle_width} ${vehicle_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="${vehicle_length/2 - rear_axle_to_back} 0 ${body_z_offset}"
              rpy="0 0 0"/>
      <geometry>
        <box size="${vehicle_length} ${vehicle_width} ${vehicle_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="${vehicle_length/2 - rear_axle_to_back} 0 ${body_z_offset}"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Rear wheels (fixed steering, driven) -->
  <xacro:wheel name="rear_left_wheel"
               x="0" y="${track_width/2}"/>
  <xacro:wheel name="rear_right_wheel"
               x="0" y="${-track_width/2}"/>

  <!-- Front wheels (steered) -->
  <xacro:steered_wheel name="front_left_wheel"
                       x="${wheelbase}" y="${track_width/2}"/>
  <xacro:steered_wheel name="front_right_wheel"
                       x="${wheelbase}" y="${-track_width/2}"/>

  <!-- LiDAR mount (placeholder) -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.02"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${vehicle_length/2 - rear_axle_to_back} 0 ${body_z_offset + vehicle_height/2 + 0.015}"
            rpy="0 0 0"/>
  </joint>

  <!-- Base footprint (ground projection) -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-wheel_radius}" rpy="0 0 0"/>
  </joint>

</robot>
