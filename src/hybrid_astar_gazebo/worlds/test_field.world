<?xml version="1.0"?>
<sdf version="1.6">
  <world name="test_field">

    <!-- Physics -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Lighting -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 1: Wall -->
    <model name="wall_1">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>2.0 0.05 0.2</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>2.0 0.05 0.2</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
          </material>
        </visual>
      </link>
      <pose>2.5 1.0 0.1 0 0 0</pose>
    </model>

    <!-- Obstacle 2: Wall -->
    <model name="wall_2">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.05 1.5 0.2</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.05 1.5 0.2</size></box>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
          </material>
        </visual>
      </link>
      <pose>1.5 2.5 0.1 0 0 0</pose>
    </model>

    <!-- Obstacle 3: Box -->
    <model name="box_1">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.4 0.4 0.2</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.4 0.4 0.2</size></box>
          </geometry>
          <material>
            <ambient>0.6 0.2 0.2 1</ambient>
          </material>
        </visual>
      </link>
      <pose>3.5 3.0 0.1 0 0 0</pose>
    </model>

    <!-- Boundary walls -->
    <model name="boundary_north">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10.0 0.05 0.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10.0 0.05 0.2</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient></material>
        </visual>
      </link>
      <pose>5.0 10.0 0.1 0 0 0</pose>
    </model>

    <model name="boundary_south">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10.0 0.05 0.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10.0 0.05 0.2</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient></material>
        </visual>
      </link>
      <pose>5.0 0.0 0.1 0 0 0</pose>
    </model>

    <model name="boundary_east">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 10.0 0.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 10.0 0.2</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient></material>
        </visual>
      </link>
      <pose>10.0 5.0 0.1 0 0 0</pose>
    </model>

    <model name="boundary_west">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 10.0 0.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 10.0 0.2</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient></material>
        </visual>
      </link>
      <pose>0.0 5.0 0.1 0 0 0</pose>
    </model>

  </world>
</sdf>
